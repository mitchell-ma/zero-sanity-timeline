{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zero-sanity-timeline",
  "main": "worker/index.ts",
  "compatibility_date": "2026-03-12",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "build",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "production": {
      "name": "zero-sanity-timeline"
    }
  }
}
